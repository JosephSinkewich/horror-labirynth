# Unity project lives in HorrorLabirynth/
# Based on https://github.com/github/gitignore/blob/main/Unity.gitignore
#
# Recommended: add any editor/OS/tool-specific ignore rules from the Global/ templates as needed.
# See: https://github.com/github/gitignore/tree/main/Global
#
HorrorLabirynth/.utmp/
HorrorLabirynth/[Ll]ibrary/
HorrorLabirynth/[Tt]emp/
HorrorLabirynth/[Oo]bj/
HorrorLabirynth/[Bb]uild/
HorrorLabirynth/[Bb]uilds/
HorrorLabirynth/[Ll]ogs/
HorrorLabirynth/[Uu]ser[Ss]ettings/
*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
*.blend1
*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
HorrorLabirynth/[Mm]emoryCaptures/

# Recordings can get excessive in size
HorrorLabirynth/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# HorrorLabirynth/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
HorrorLabirynth/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
*.DotSettings.user

# Visual Studio cache directory
HorrorLabirynth/.vs/
.vs/

# Gradle cache directory
HorrorLabirynth/.gradle/
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
HorrorLabirynth/ExportedObj/
ExportedObj/
HorrorLabirynth/.consulo/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Mono auto generated files
mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
crashlytics-build.properties

# TestRunner generated files
InitTestScene*.unity*

# Addressables default ignores, before user customizations
HorrorLabirynth/ServerData
HorrorLabirynth/[Aa]ssets/StreamingAssets/aa*
HorrorLabirynth/[Aa]ssets/AddressableAssetsData/link.xml*
HorrorLabirynth/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# HorrorLabirynth/Assets/AddressableAssetsData/OSX/addressables_content_state.bin
HorrorLabirynth/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
HorrorLabirynth/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
HorrorLabirynth/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
HorrorLabirynth/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
HorrorLabirynth/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
HorrorLabirynth/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Auto-generated cache in Assets folder
HorrorLabirynth/[Aa]ssets/[Ss]ceneDependencyCache*
